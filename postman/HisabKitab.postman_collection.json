{
  "info": {
    "name": "HisabKitab API",
    "description": "Family expense tracker backend. Set the `baseUrl` and `token` collection variables — `token` is a Supabase access token (JWT). All requests except Health use Bearer auth automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "familyId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Vouchers",
      "item": [
        {
          "name": "Create Voucher (quick save)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/vouchers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"items\": [{ \"amount\": 250 }]\n}"
            }
          }
        },
        {
          "name": "Create Voucher (multi-item)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/vouchers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"category_id\": \"bazaar\",\n  \"items\": [\n    { \"name\": \"Rice 5kg\", \"amount\": 400.5 },\n    { \"name\": \"Lentils\", \"amount\": 130.25 },\n    { \"name\": \"Fish\", \"amount\": 650 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Family Voucher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/vouchers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"category_id\": \"dining\",\n  \"family_id\": \"{{familyId}}\",\n  \"items\": [{ \"name\": \"Iftar\", \"amount\": 800 }]\n}"
            }
          }
        },
        {
          "name": "List Vouchers (solo feed)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/vouchers?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vouchers"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "List Vouchers (family feed)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/vouchers?family_id={{familyId}}&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vouchers"],
              "query": [
                { "key": "family_id", "value": "{{familyId}}" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "OCR Receipt",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/vouchers/ocr",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image_url\": \"https://your-project.supabase.co/storage/v1/object/public/hisabkitab-voucher/sample.webp\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/categories"
          }
        },
        {
          "name": "List Expense Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories?type=expense",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories"],
              "query": [{ "key": "type", "value": "expense" }]
            }
          }
        }
      ]
    },
    {
      "name": "Family",
      "item": [
        {
          "name": "Create Family",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/family",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Amader Songshar\"\n}"
            }
          }
        },
        {
          "name": "My Families",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/family"
          }
        },
        {
          "name": "Invite Member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/family/invite",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"spouse@example.com\"\n}"
            }
          }
        },
        {
          "name": "Join Family",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/family/join",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"paste-join-code-here\"\n}"
            }
          }
        }
      ]
    }
  ]
}
