# MongoDB Atlas connection string (M0 free tier) — local default below
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=hisabkitab

# Supabase project settings (Dashboard -> Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated

# Groq key + vision model for receipt OCR (FR-6)
GROQ_API_KEY=gsk_...
OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

DEBUG=false

# Comma-separated browser origins allowed by CORS ("*" only for local dev)
CORS_ORIGINS=*

# Rotating log file (5MB x 3); leave empty to log to stdout only
LOG_FILE=server.log
